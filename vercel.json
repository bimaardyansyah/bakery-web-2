{
    "version": 2,
    "framework": null,
    "outputDirectory": "public",
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "public"
            }
        },
        {
            "src": "api/index.php",
            "use": "vercel-php@0.9.0"
        }
    ],
    "routes": [
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_KEY": "base64:2rgrT85cbsRiuqdnBtLnZJevIHqnkCxRMwx9wxWaaUA=",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "CACHE_STORE": "array",
        "APP_STORAGE_PATH": "/tmp/storage",
        "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
        "ASSET_URL": "https://bakery-web-2.vercel.app",
        "APP_CONFIG_CACHE": "/tmp/storage/bootstrap/cache/config.php",
        "APP_EVENTS_CACHE": "/tmp/storage/bootstrap/cache/events.php",
        "APP_PACKAGES_CACHE": "/tmp/storage/bootstrap/cache/packages.php",
        "APP_ROUTES_CACHE": "/tmp/storage/bootstrap/cache/routes.php",
        "APP_SERVICES_CACHE": "/tmp/storage/bootstrap/cache/services.php"
    }
}
